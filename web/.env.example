# ============================================================
# web/ (Next.js 管理画面) 環境変数サンプル
# ローカルは web/.env.local にコピーして設定。本番は Vercel の環境変数に設定。
# env が無いとき（プレビュー等）はモックで動作し、ログインゲートも無効になる。
# 実データ接続するとブラウザから実 LINE 送信が可能になるため、env 投入は
# アクセス制御された環境（＝このログインゲートが効く本番）でのみ行うこと。
# ============================================================

# --- Supabase 認証（クライアントに出てよい公開値）---
# 設定するとログイン必須になる（middleware で全ページをゲート）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- サーバー専用（ブラウザに出さない。NEXT_PUBLIC_ を付けない）---
# messages 等の読み取り・staff 参照・reply_events 記録に使う service_role キー。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# send-reply Edge Function を叩く管理者シークレット
ADMIN_SECRET=your-strong-random-secret
