# ============================================================
# Web 返信管理画面（Next.js）環境変数サンプル
# このファイルを web/.env.local にコピーして値を設定する。
# .env.local は Git にコミットしない。
# ============================================================

# --- Supabase（サーバ側のみ。ブラウザには出ない）---
# Edge Function と同じプロジェクトを指す。
SUPABASE_URL=https://your-project-id.supabase.co
# service_role キー（管理者権限・絶対に公開しない）。サーバ(API Route)でのみ使用。
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Supabase（ブラウザ側 / Realtime 購読専用）---
# NEXT_PUBLIC_* はブラウザに露出する。anon 鍵は公開前提のキー。
# 本アプリではテーブル本文の取得には使わず、変更通知(broadcast)の購読だけに使う。
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- send-reply Edge Function 連携 ---
# 返信送信時にサーバから呼び出す。ADMIN_SECRET は Edge Function 側と一致させる。
ADMIN_SECRET=your-strong-random-secret

# --- 画面アクセス認証（簡易・共有パスワード）---
# スタッフ全員で共有する1つのパスワード。ログイン画面で入力する。
APP_PASSWORD=set-a-shared-password
# ログインセッションのクッキー署名鍵（openssl rand -base64 32 などで生成）。
APP_SESSION_SECRET=set-a-long-random-secret
