# web/ (Next.js) のサーバー側 env。実値は web/.env.local に置く（gitignore 済み）。
# いずれも NEXT_PUBLIC_ を付けないこと（ブラウザに出さないため）。

# Supabase（service_role キー。RLS をバイパスして templates / reply_feedback を読む）
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx   # 旧 service_role 相当（新形式）

# Anthropic（返信ドラフト生成。Claude Haiku 4.5 既定）
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # 既定を変えたい場合のみ

# 取得件数の既定（最適解の模索用。リクエストの n / exN でも上書き可）
# GENERATE_TEMPLATE_N=6
# GENERATE_EXAMPLE_N=4
