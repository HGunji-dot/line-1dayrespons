# ============================================================
# LINE未返信通知システム 環境変数サンプル
# このファイルをコピーして .env を作成し、各値を設定してください。
# .env は絶対にGitにコミットしないでください。
# 本番環境では GitHub Secrets に登録するほか、Edge Function 用は Supabase CLI の
# secrets set で LINE_* / ADMIN_* だけを設定する（SUPABASE_URL・service_role はホスト側が注入）。
# ============================================================

# --- Supabase ---
# SupabaseプロジェクトのURL
# 例: https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service_role キー（管理者権限。外部に漏らさないこと）
# Supabase管理画面 > Settings > API > service_role key
SUPABASE_KEY=your-supabase-service-role-key

# --- LINE Messaging API ---
# チャネルシークレット（Webhook署名検証に使用）
# LINE Developers > チャネル > チャネル基本設定 > チャネルシークレット
LINE_CHANNEL_SECRET=your-line-channel-secret

# チャネルアクセストークン（ユーザープロフィール取得に使用）
# LINE Developers > チャネル > Messaging API設定 > チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# --- 未返信アラートの送信先（Messaging API）---
# LINE Notify は 2025/3/31 終了のため、公式アカウントの Push で管理者に通知します。
# 管理者の LINE ユーザーID（U で始まる）をカンマ区切り。複数人に同報できます。
# 取得例: 管理者がボットにトークを送ったあと、Supabase の messages テーブルの user_id を確認する。
ADMIN_NOTIFY_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# --- send-reply Edge Function 認証 ---
# 管理者が返信を送る際に使う秘密トークン（任意の長いランダム文字列）
# 例: openssl rand -base64 32 で生成
ADMIN_SECRET=your-strong-random-secret

# --- webhook-receiver: L-Step Webhook転送 用の共有シークレット ---
# L-Step がイベントを転送してくる際、x-line-signature が検証できるとは限らないため、
# 転送先 URL に ?k=<RELAY_SECRET> を付けて認証する（URL 自体を秘密にする）。
# webhook-receiver は「LINE署名」か「この共有シークレット」のどちらかが通れば受理する。
# 例: openssl rand -base64 32 で生成。未設定なら従来どおり LINE 署名のみで認証。
RELAY_SECRET=your-strong-random-relay-secret

# --- 設定（任意） ---
# 未返信とみなす時間数（デフォルト: 24）
UNREPLIED_HOURS=24
# 同じユーザーへの再通知間隔・時間数（デフォルト: 24）
# 返信があるまで RE_NOTIFY_HOURS ごとに1回だけ通知する
RE_NOTIFY_HOURS=24
